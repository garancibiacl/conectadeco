# ================================================================
# .env.example — ConectaDeco Backend
# Copia este archivo como .env y completa los valores
# NUNCA subas .env a git
# ================================================================

# ── Servidor ────────────────────────────────────────────────────
PORT=3000
API_HOST=localhost
NODE_ENV=development          # cambiar a "production" en Render

# ── Frontend (CORS) ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173   # en Render: URL de Vercel/Render del frontend

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=define_un_secreto_seguro_aqui
JWT_EXPIRES_IN=7d

# ── Base de datos ───────────────────────────────────────────────
# OPCIÓN A — Render (producción): pega la "Internal Database URL" de Render
DATABASE_URL=postgresql://usuario:password@host.render.com:5432/nombre_db

# OPCIÓN B — Local (desarrollo): variables individuales
# Comenta DATABASE_URL y descomenta estas líneas:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=conectadeco
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_SSL=false
